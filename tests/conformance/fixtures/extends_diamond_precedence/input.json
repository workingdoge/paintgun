{
  "base": {
    "$type": "dimension",
    "scale": {
      "xs": { "$value": { "value": 4, "unit": "px" } },
      "sm": { "$value": { "value": 8, "unit": "px" } }
    }
  },
  "a": {
    "$extends": "base",
    "scale": {
      "sm": { "$value": { "value": 10, "unit": "px" } },
      "md": { "$value": { "value": 16, "unit": "px" } }
    }
  },
  "b": {
    "$extends": "base",
    "scale": {
      "sm": { "$value": { "value": 12, "unit": "px" } },
      "lg": { "$value": { "value": 24, "unit": "px" } }
    }
  },
  "component": {
    "$extends": "a",
    "scale": {
      "$extends": "b.scale",
      "xl": { "$value": { "value": 32, "unit": "px" } }
    }
  }
}
