{
  "brand colors": {
    "$type": "number",
    "primary": { "$value": 4 },
    "aliasCurly": { "$value": "{brand colors.primary}" },
    "aliasPointer": { "$value": "{#/brand colors/primary/$value}" }
  },
  "my/group~family": {
