{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "allowJs": false,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["bun-types"]
  },
  "include": [".storybook/**/*.ts", "scripts/**/*.ts", "src/**/*.ts", "tests/**/*.ts"]
}
