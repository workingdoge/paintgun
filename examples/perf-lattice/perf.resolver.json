                  "alpha": 1,
                  "hex": "#111111"
                }
              }
            }
          },
          "dimension": {
            "space": {
              "md": {
                "$type": "dimension",
                "$value": {
                  "value": "8",
                  "unit": "px"
                }
              }
            },
            "radius": {
              "md": {
                "$type": "dimension",
                "$value": {
                  "value": "6",
                  "unit": "px"
                }
              }
