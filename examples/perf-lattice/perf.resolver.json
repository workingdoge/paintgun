  "description": "Synthetic fixture for context-scaling metrics",
  "sets": {
    "base": {
      "sources": [
        {
          "color": {
            "surface": {
              "bg": {
                "$type": "color",
                "$value": {
                  "colorSpace": "srgb",
                  "components": [
                    1,
                    1,
                    1
