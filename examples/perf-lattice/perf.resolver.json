{
  "name": "Perf Lattice",
  "version": "2025.10",
  "description": "Synthetic fixture for context-scaling metrics",
  "sets": {
    "base": {
      "sources": [
        {
          "color": {
            "surface": {
              "bg": {
                "$type": "color",
                "$value": {
                  "colorSpace": "srgb",
                  "components": [1, 1, 1],
                  "alpha": 1,
                  "hex": "#ffffff"
                }
              }
            },
            "text": {
              "primary": {
                "$type": "color",
                "$value": {
                  "colorSpace": "srgb",
                  "components": [0.066667, 0.066667, 0.066667],
                  "alpha": 1,
                  "hex": "#111111"
                }
              }
            }
          },
          "dimension": {
            "space": {
              "md": {
                "$type": "dimension",
                "$value": {
                  "value": "8",
                  "unit": "px"
                }
              }
            },
            "radius": {
              "md": {
                "$type": "dimension",
                "$value": {
                  "value": "6",
                  "unit": "px"
                }
              }
            }
          },
          "duration": {
            "fast": {
              "$type": "duration",
              "$value": {
                "value": "120",
                "unit": "ms"
              }
            }
          }
        }
      ]
    }
  },
