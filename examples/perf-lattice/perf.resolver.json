                  "alpha": 1,
                  "hex": "#ffffff"
                }
              }
            },
            "text": {
              "primary": {
                "$type": "color",
                "$value": {
                  "colorSpace": "srgb",
                  "components": [
                    0.066667,
                    0.066667,
                    0.066667
