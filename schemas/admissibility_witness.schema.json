{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workingdoge.com/premath/schemas/admissibility-witness.schema.json",
  "title": "Premath Admissibility Witness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witnessSchema",
    "profile",
    "result",
    "failures"
  ],
  "properties": {
    "witnessSchema": {
      "type": "integer",
      "const": 1
    },
    "profile": {
      "type": "string",
      "const": "full"
    },
    "result": {
      "type": "string",
      "enum": [
        "accepted",
        "rejected"
      ]
    },
    "failures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/failure"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "result": {
            "const": "accepted"
          }
        }
      },
      "then": {
        "properties": {
          "failures": {
            "type": "array",
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "result": {
            "const": "rejected"
          }
        }
      },
      "then": {
        "properties": {
          "failures": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceId": {
          "type": "string",
          "minLength": 1
        },
        "filePath": {
          "type": "string",
          "minLength": 1
        },
        "jsonPointer": {
          "type": "string",
          "minLength": 1
        },
        "fileHash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "witnessId",
        "class",
        "lawRef",
        "message"
      ],
      "properties": {
        "witnessId": {
          "type": "string",
          "minLength": 1
        },
        "class": {
          "type": "string",
          "enum": [
            "stability_failure",
            "locality_failure",
            "descent_failure",
            "glue_non_contractible",
            "adjoint_triple_coherence_failure"
          ]
        },
        "lawRef": {
          "type": "string",
          "pattern": "^GATE-[0-9]+\\.[0-9]+$"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "context": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          ]
        },
        "tokenPath": {
          "type": "string",
          "minLength": 1
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source"
          }
        },
        "details": {
          "type": "object"
        }
      }
    }
  }
}
