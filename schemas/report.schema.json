{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://paintgun.dev/schemas/report.schema.json",
  "title": "Paintgun Diagnostic Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reportVersion",
    "reportKind",
    "conflictMode",
    "policyDigest",
    "summary",
    "counts",
    "findings"
  ],
  "properties": {
    "reportVersion": {
      "type": "integer",
      "enum": [1]
    },
    "reportKind": {
      "type": "string",
      "enum": ["pack", "compose"]
    },
    "conflictMode": {
      "type": "string",
      "enum": ["semantic", "normalized"]
    },
    "policyDigest": { "type": "string" },
    "normalizerVersion": { "type": "string" },
    "summary": {
      "type": "object"
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "byKind"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "byKind": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/definitions/finding" }
    },
    "plannerTrace": {
      "$ref": "#/definitions/plannerTrace"
    }
  },
  "definitions": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["witnessId", "kind", "severity", "message"],
      "properties": {
        "witnessId": { "type": "string" },
        "kind": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["error", "warn", "info"]
        },
        "message": { "type": "string" },
        "tokenPath": { "type": "string" },
        "context": { "type": "string" },
        "filePath": { "type": "string" },
        "jsonPointer": { "type": "string" },
        "pack": { "type": "string" }
      }
    },
    "plannerTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "scope",
        "mode",
        "axisUniverse",
        "relevantAxes",
        "contractTokens",
        "counts",
        "truncated",
        "included",
        "resolverIncluded",
        "excluded"
      ],
      "properties": {
        "version": {
          "type": "integer",
          "enum": [1]
        },
        "scope": {
          "type": "string",
          "enum": ["build", "compose"]
        },
        "mode": {
          "type": "string",
          "enum": ["full-only", "partial", "from-contracts"]
        },
        "axisUniverse": {
          "type": "array",
          "items": { "type": "string" }
        },
        "relevantAxes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "contractTokens": {
          "type": "array",
          "items": { "type": "string" }
        },
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "universe",
            "analysisIncluded",
            "resolverIncluded",
            "excluded"
          ],
          "properties": {
            "universe": { "type": "integer", "minimum": 0 },
            "analysisIncluded": { "type": "integer", "minimum": 0 },
            "resolverIncluded": { "type": "integer", "minimum": 0 },
            "excluded": { "type": "integer", "minimum": 0 }
          }
        },
        "truncated": {
          "type": "object",
          "additionalProperties": false,
          "required": ["included", "resolverIncluded", "excluded"],
          "properties": {
            "included": { "type": "integer", "minimum": 0 },
            "resolverIncluded": { "type": "integer", "minimum": 0 },
            "excluded": { "type": "integer", "minimum": 0 }
          }
        },
        "included": {
          "type": "array",
          "items": { "$ref": "#/definitions/plannerTraceEntry" }
        },
        "resolverIncluded": {
          "type": "array",
          "items": { "$ref": "#/definitions/plannerTraceEntry" }
        },
        "excluded": {
          "type": "array",
          "items": { "$ref": "#/definitions/plannerTraceEntry" }
        }
      }
    },
    "plannerTraceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["context", "rule", "source"],
      "properties": {
        "context": { "type": "string" },
        "rule": { "type": "string" },
        "source": { "type": "string" }
      }
    }
  }
}
