{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://paintgun.dev/schemas/report.schema.json",
  "title": "Paintgun Diagnostic Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reportVersion",
    "reportKind",
    "conflictMode",
    "policyDigest",
    "summary",
    "counts",
    "findings"
  ],
  "properties": {
    "reportVersion": {
      "type": "integer",
      "enum": [1]
    },
    "reportKind": {
      "type": "string",
      "enum": ["pack", "compose"]
    },
    "conflictMode": {
      "type": "string",
      "enum": ["semantic", "normalized"]
    },
    "policyDigest": { "type": "string" },
    "normalizerVersion": { "type": "string" },
    "summary": {
      "type": "object"
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "byKind"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "byKind": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/definitions/finding" }
    },
    "backendArtifacts": {
      "type": "array",
      "items": { "$ref": "#/definitions/backendArtifact" }
    },
    "plannerTrace": {
      "$ref": "#/definitions/plannerTrace"
    },
    "guardrails": {
      "$ref": "#/definitions/guardrails"
    },
    "rollups": {
      "$ref": "#/definitions/rollups"
    }
  },
  "definitions": {
    "backendArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backendId", "kind", "file", "sha256", "size"],
      "properties": {
        "backendId": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": [
            "primaryTokenOutput",
            "tokenStylesheet",
            "systemStylesheet",
            "typeDeclarations",
            "packageManifest",
            "packageSettings",
            "packageBuildScript",
            "packageSource",
            "packageTest"
          ]
        },
        "file": { "type": "string" },
        "sha256": { "type": "string" },
        "size": { "type": "integer", "minimum": 0 },
        "apiVersion": { "type": "string" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["witnessId", "kind", "severity", "message"],
      "properties": {
        "witnessId": { "type": "string" },
        "kind": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["error", "warn", "info"]
        },
        "message": { "type": "string" },
        "tokenPath": { "type": "string" },
        "context": { "type": "string" },
        "filePath": { "type": "string" },
        "jsonPointer": { "type": "string" },
        "pack": { "type": "string" }
      }
    },
    "plannerTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "scope",
        "mode",
        "axisUniverse",
        "relevantAxes",
        "contractTokens",
        "counts",
        "truncated",
        "included",
        "resolverIncluded",
        "excluded"
      ],
      "properties": {
        "version": {
          "type": "integer",
          "enum": [1]
        },
        "scope": {
          "type": "string",
          "enum": ["build", "compose"]
        },
        "mode": {
          "type": "string",
          "enum": ["full-only", "partial", "from-contracts"]
        },
        "axisUniverse": {
          "type": "array",
          "items": { "type": "string" }
        },
        "relevantAxes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "contractTokens": {
          "type": "array",
          "items": { "type": "string" }
        },
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "universe",
            "analysisIncluded",
            "resolverIncluded",
            "excluded"
          ],
          "properties": {
            "universe": { "type": "integer", "minimum": 0 },
            "analysisIncluded": { "type": "integer", "minimum": 0 },
            "resolverIncluded": { "type": "integer", "minimum": 0 },
            "excluded": { "type": "integer", "minimum": 0 }
          }
        },
        "truncated": {
          "type": "object",
          "additionalProperties": false,
          "required": ["included", "resolverIncluded", "excluded"],
          "properties": {
            "included": { "type": "integer", "minimum": 0 },
            "resolverIncluded": { "type": "integer", "minimum": 0 },
            "excluded": { "type": "integer", "minimum": 0 }
          }
        },
        "included": {
          "type": "array",
          "items": { "$ref": "#/definitions/plannerTraceEntry" }
        },
        "resolverIncluded": {
          "type": "array",
          "items": { "$ref": "#/definitions/plannerTraceEntry" }
        },
        "excluded": {
          "type": "array",
          "items": { "$ref": "#/definitions/plannerTraceEntry" }
        }
      }
    },
    "plannerTraceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["context", "rule", "source"],
      "properties": {
        "context": { "type": "string" },
        "rule": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planner", "witnesses"],
      "properties": {
        "planner": { "$ref": "#/definitions/plannerGuardrail" },
        "witnesses": { "$ref": "#/definitions/witnessGuardrail" }
      }
    },
    "plannerGuardrail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "summary",
        "packCount",
        "contextsChecked",
        "warnAtPackCount",
        "warnAtContextsChecked"
      ],
      "properties": {
        "status": { "type": "string", "enum": ["ok", "warn"] },
        "summary": { "type": "string" },
        "packCount": { "type": "integer", "minimum": 0 },
        "contextsChecked": { "type": "integer", "minimum": 0 },
        "analysisIncluded": { "type": "integer", "minimum": 0 },
        "analysisUniverse": { "type": "integer", "minimum": 0 },
        "warnAtPackCount": { "type": "integer", "minimum": 0 },
        "warnAtContextsChecked": { "type": "integer", "minimum": 0 }
      }
    },
    "witnessGuardrail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "summary",
        "conflictCount",
        "findingCount",
        "detailLimit",
        "warnAtConflicts",
        "warnAtFindings"
      ],
      "properties": {
        "status": { "type": "string", "enum": ["ok", "warn"] },
        "summary": { "type": "string" },
        "conflictCount": { "type": "integer", "minimum": 0 },
        "findingCount": { "type": "integer", "minimum": 0 },
        "detailLimit": { "type": "integer", "minimum": 0 },
        "warnAtConflicts": { "type": "integer", "minimum": 0 },
        "warnAtFindings": { "type": "integer", "minimum": 0 }
      }
    },
    "rollups": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tokenPaths", "winnerPacks", "packSets"],
      "properties": {
        "tokenPaths": {
          "type": "array",
          "items": { "$ref": "#/definitions/rollupEntry" }
        },
        "winnerPacks": {
          "type": "array",
          "items": { "$ref": "#/definitions/rollupEntry" }
        },
        "packSets": {
          "type": "array",
          "items": { "$ref": "#/definitions/rollupEntry" }
        }
      }
    },
    "rollupEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "count"],
      "properties": {
        "key": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
