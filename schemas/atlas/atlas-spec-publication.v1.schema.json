{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.workingdoge.com/schemas/atlas-spec-publication.v1.schema.json",
  "title": "Atlas Spec Publication Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "site", "sourceRoot", "series"],
  "properties": {
    "schema": {
      "const": "atlas.spec-publication.v1"
    },
    "site": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]*$"
    },
    "sourceRoot": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "^/" },
          { "pattern": "(^|/)\\.\\.(/|$)" }
        ]
      }
    },
    "series": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/series"
      }
    }
  },
  "$defs": {
    "series": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "documents"],
      "properties": {
        "id": {
          "$ref": "#/$defs/pathSegment"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "documents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/document"
          }
        }
      }
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "status", "category", "path"],
      "properties": {
        "id": {
          "$ref": "#/$defs/pathSegment"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "category": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "anyOf": [
              { "pattern": "^/" },
              { "pattern": "(^|/)\\.\\.(/|$)" }
            ]
          }
        },
        "order": {
          "type": "integer"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "pathSegment": {
      "type": "string",
      "minLength": 1,
      "not": {
        "enum": [".", ".."]
      },
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    }
  }
}
