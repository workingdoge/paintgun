{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Paintgun design-tool-neutral catalog IR",
  "type": "object",
  "required": ["catalogSystem", "catalogComponents"],
  "properties": {
    "catalogSystem": {
      "type": "object",
      "required": [
        "id",
        "title",
        "release",
        "schemaVersion",
        "catalogVersion",
        "paintSources",
        "artifactReferences",
        "verificationSummary"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "release": { "type": "string", "minLength": 1 },
        "schemaVersion": { "type": "string", "minLength": 1 },
        "catalogVersion": { "type": "string", "minLength": 1 },
        "paintSources": {
          "type": "array",
          "items": { "$ref": "#/definitions/catalogSource" }
        },
        "artifactReferences": {
          "type": "array",
          "items": { "$ref": "#/definitions/artifactReference" }
        },
        "verificationSummary": { "$ref": "#/definitions/verificationSummary" }
      },
      "additionalProperties": false
    },
    "catalogComponents": {
      "type": "array",
      "items": { "$ref": "#/definitions/catalogComponent" }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "catalogSource": {
      "type": "object",
      "required": [
        "id",
        "manifest",
        "diagnostics",
        "tool",
        "spec",
        "packIdentity"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "manifest": { "type": "string", "minLength": 1 },
        "diagnostics": { "type": "string", "minLength": 1 },
        "tool": {
          "type": "object",
          "required": ["name", "version"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "spec": { "type": "string", "minLength": 1 },
        "packIdentity": {
          "type": "object",
          "required": ["packId", "packVersion", "contentHash"],
          "properties": {
            "packId": { "type": "string", "minLength": 1 },
            "packVersion": { "type": "string", "minLength": 1 },
            "contentHash": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]+$"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "artifactReference": {
      "type": "object",
      "required": ["sourceId", "backendId", "kind", "file", "sha256", "size"],
      "properties": {
        "sourceId": { "type": "string", "minLength": 1 },
        "backendId": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "file": { "type": "string", "minLength": 1 },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]+$"
        },
        "size": { "type": "integer", "minimum": 0 },
        "apiVersion": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "verificationSummary": {
      "type": "object",
      "required": ["scope", "total", "clean", "families", "severities", "reports"],
      "properties": {
        "scope": {
          "type": "string",
          "enum": ["system", "system-wide", "component"]
        },
        "total": { "type": "integer", "minimum": 0 },
        "clean": { "type": "boolean" },
        "families": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["familyId", "familyLabel", "count"],
            "properties": {
              "familyId": { "type": "string", "minLength": 1 },
              "familyLabel": { "type": "string", "minLength": 1 },
              "count": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "severities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["severity", "count"],
            "properties": {
              "severity": { "type": "string", "minLength": 1 },
              "count": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "reports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["sourceId", "file", "reportKind", "backendIds", "total", "clean"],
            "properties": {
              "sourceId": { "type": "string", "minLength": 1 },
              "file": { "type": "string", "minLength": 1 },
              "reportKind": { "type": "string", "minLength": 1 },
              "backendIds": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "total": { "type": "integer", "minimum": 0 },
              "clean": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "catalogComponent": {
      "type": "object",
      "required": [
        "id",
        "title",
        "description",
        "status",
        "compatibility",
        "accessibility",
        "parts",
        "slots",
        "inputs",
        "examples",
        "tokenRoleBindings",
        "artifactScope",
        "artifactReferences",
        "verificationSummary"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "compatibility": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean"]
          }
        },
        "accessibility": {
          "type": "object",
          "required": ["role", "notes"],
          "properties": {
            "role": { "type": "string", "minLength": 1 },
            "notes": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "additionalProperties": false
        },
        "parts": {
          "type": "array",
          "items": { "$ref": "#/definitions/namedDescription" }
        },
        "slots": {
          "type": "array",
          "items": { "$ref": "#/definitions/namedDescription" }
        },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/definitions/componentInput" }
        },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/definitions/componentExample" }
        },
        "tokenRoleBindings": {
          "type": "array",
          "items": { "$ref": "#/definitions/tokenRoleBinding" }
        },
        "artifactScope": {
          "type": "string",
          "enum": ["component", "system-wide"]
        },
        "artifactReferences": {
          "type": "array",
          "items": { "$ref": "#/definitions/artifactReference" }
        },
        "verificationSummary": { "$ref": "#/definitions/verificationSummary" }
      },
      "additionalProperties": false
    },
    "namedDescription": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "componentInput": {
      "type": "object",
      "required": ["name", "label", "description", "kind", "default"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "default": { "type": ["string", "boolean"] },
        "options": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "componentExample": {
      "type": "object",
      "required": ["id", "label", "context", "inputs", "content"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "context": { "type": "string", "minLength": 1 },
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "boolean"]
          }
        },
        "content": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "tokenRoleBinding": {
      "type": "object",
      "required": ["role", "token"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "token": { "type": "string", "minLength": 1 },
        "notes": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
